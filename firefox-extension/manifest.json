{
  "manifest_version": 3,
  "name": "Discord Widget Configurator",
  "version": "1.6.2",
  "description": "One-click Discord profile widget configurator. Fully automatic with a live on-page console.",
  "icons": {
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "discord-widget-creator@local",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": [
    "https://discord.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/developers/*"
      ],
      "js": [
        "widget-creator.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://discord.com/developers/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
